  id                                           BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  document_type_warranty_id                    Int
  company_id                                   BigInt             @db.UnsignedBigInt
  branch_id                                    BigInt             @db.UnsignedBigInt
  branch_sale_id                               BigInt?            @db.UnsignedBigInt
  serie                                        String             @db.VarChar(10)
  correlative                                  String             @db.VarChar(10)
  article_id                                   BigInt?            @db.UnsignedBigInt
  serie_art                                    String?            @db.VarChar(50)
  date                                         DateTime           @db.Date
  reference_sale_id                            BigInt?            @db.UnsignedBigInt
  customer_id                                  BigInt?            @db.UnsignedBigInt
  customer_phone                               String?            @db.VarChar(9)
  customer_email                               String?            @db.VarChar(150)
  failure_description                          String?            @db.Text
  observations                                 String?            @db.Text
  diagnosis                                    String?            @db.Text
  supplier_id                                  BigInt?            @db.UnsignedBigInt
  entry_guide_id                               BigInt?            @db.UnsignedBigInt
  contact                                      String?            @db.VarChar(100)
  follow_up_diagnosis                          String?            @db.VarChar(150)
  follow_up_status                             String?            @db.VarChar(150)
  solution                                     String?            @db.VarChar(150)
  warranty_status_id                           BigInt?            @db.UnsignedBigInt
  solution_date                                DateTime?          @db.Date
  delivery_description                         String?            @db.Text
  delivery_serie_art                           String?            @db.VarChar(50)
  credit_note_serie                            String?            @db.VarChar(10)
  credit_note_correlative                      String?            @db.VarChar(10)
  delivery_date                                DateTime?          @db.Date
  dispatch_note_serie                          String?            @db.VarChar(10)
  dispatch_note_correlative                    String?            @db.VarChar(10)
  dispatch_note_date                           DateTime?          @db.Date
  created_at                                   DateTime?          @db.DateTime(0)
  updated_At                                   DateTime?          @db.DateTime(0)
  articles                                     articles?          @relation(fields: [article_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "article_id_foreign")
  branches_warranties_branch_idTobranches      branches           @relation("warranties_branch_idTobranches", fields: [branch_id], references: [id], onUpdate: Restrict, map: "branch_id_foreign")
  branches_warranties_branch_sale_idTobranches branches?          @relation("warranties_branch_sale_idTobranches", fields: [branch_sale_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "branch_sale_id_foreign")
  companies                                    companies          @relation(fields: [company_id], references: [id], onUpdate: Restrict, map: "company_id_foreign")
  customers_warranties_customer_idTocustomers  customers?         @relation("warranties_customer_idTocustomers", fields: [customer_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "customer_id_foreign")
  entry_guides                                 entry_guides?      @relation(fields: [entry_guide_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "entry_guide_id_foreign")
  sales                                        sales?             @relation(fields: [reference_sale_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "reference_sale_id_foreign")
  customers_warranties_supplier_idTocustomers  customers?         @relation("warranties_supplier_idTocustomers", fields: [supplier_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "supplier_id_foreign")
  warranty_statuses                            warranty_statuses? @relation(fields: [warranty_status_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "warranty_status_id_foreign")

  @@unique([company_id, branch_id, document_type_warranty_id, serie, correlative], map: "company_id")
  @@index([article_id], map: "article_id_foreign")
  @@index([branch_id], map: "branch_id_foreign")
  @@index([branch_sale_id], map: "branch_sale_id_foreign")
  @@index([company_id], map: "company_id_foreign")
  @@index([customer_id], map: "customer_id_foreign")
  @@index([entry_guide_id], map: "entry_guide_id_foreign")
  @@index([reference_sale_id], map: "reference_sale_id_foreign")
  @@index([supplier_id], map: "supplier_id_foreign")
  @@index([warranty_status_id], map: "warranty_status_id_foreign")
}

model warranty_statuses {
  id          BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  name        String       @db.VarChar(100)
  color       String?      @db.VarChar(20)
  st_warranty Boolean?
  st_support  Boolean?
  status      Boolean      @default(true)
  warranties  warranties[]
}

model withholdings {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  date       DateTime  @db.Date
  percentage Decimal   @db.Decimal(6, 2)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model order_items {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  order_id   BigInt   @db.UnsignedBigInt
  article_id BigInt   @db.UnsignedBigInt
  quantity   Int      @default(1)
  unit_price Decimal  @db.Decimal(10, 2)
  subtotal   Decimal  @db.Decimal(10, 2)
  created_at DateTime @default(now()) @db.Timestamp(0)
  orders     orders   @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "order_items_ibfk_1")
  articles   articles @relation(fields: [article_id], references: [id], onUpdate: Restrict, map: "order_items_ibfk_2")

  @@index([article_id], map: "idx_order_items_article_id")
  @@index([order_id], map: "idx_order_items_order_id")
}

model orders {
  id          BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  client_id   BigInt         @db.UnsignedBigInt
  total       Decimal        @default(0.00) @db.Decimal(10, 2)
  status      orders_status? @default(processing)
  created_at  DateTime       @default(now()) @db.Timestamp(0)
  order_items order_items[]
  clients     clients        @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_orders_client")

  @@index([client_id], map: "fk_orders_client")
}

model hero_slides {
  id         BigInt    @id @default(autoincrement())
  title      String    @db.VarChar(255)
  subtitle   String?   @db.VarChar(255)
  image      String    @db.VarChar(255)
  link       String?   @db.VarChar(255)
  orden      Int
  active     Boolean?  @default(true)
  created_at DateTime? @default(now()) @db.DateTime(0)
  name       String    @db.VarChar(255)
}

enum orders_status {
  pending
  paid
  processing
  shipped
  delivered
  cancelled
}
